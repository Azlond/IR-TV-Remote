{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ESNext", "DOM"],
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["src/**/*", "server.ts", "vite.config.ts"],
    "exclude": ["node_modules", "dist"]
}
